# Mira relay — store sidecar configuration
#
# The relay persists each transmission's transcoded audio to S3, a metadata
# record to DynamoDB, and a transcription job to SQS, as a fire-and-forget
# sidecar that NEVER blocks live audio.
#
# Local dev / tests: leave MIRA_S3_BUCKET and MIRA_DDB_TABLE unset (or set
# MIRA_STORE=noop). The relay then uses a no-op store and no-op queue — no AWS
# calls, no budget spend, no credentials required.

# Force the local no-op store + queue even if config is set. Handy for dev.
# MIRA_STORE=noop

# Target S3 bucket for transcoded audio (audio/mp4). Required to enable persistence.
# MIRA_S3_BUCKET=mira-transmissions

# Target DynamoDB table (event operational memory). Required to enable persistence.
# MIRA_DDB_TABLE=mira-events

# Target SQS queue for transcription jobs. Optional: unset = no STT enqueue.
# MIRA_SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/mira-transcription

# Identifier for this relay instance, recorded on every transmission (relayId).
# MIRA_RELAY_ID=relay-a

# AWS region (default: us-east-1)
# AWS_REGION=us-east-1

# AWS credentials are resolved by the default AWS SDK provider chain
# (env vars, shared config/credentials file, or the EC2 instance role).
# NEVER hardcode secrets in the repo.
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
